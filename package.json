  "private": true,
  "scripts": {
    "dev": "node --use-system-ca node_modules/next/dist/bin/next dev -p 3001",
    "build": "node --use-system-ca node_modules/next/dist/bin/next build --turbopack",
    "start": "node --use-system-ca node_modules/next/dist/bin/next start -p 3001",
