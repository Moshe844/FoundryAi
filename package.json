    "eval:provider-resilience": "node scripts/eval-provider-resilience.cjs",
    "eval:preview-source-contract": "node scripts/eval-preview-source-contract.cjs",
    "eval:attachment-lifecycle": "node scripts/eval-attachment-lifecycle.cjs",
    "eval:project-deletion-recovery": "node scripts/eval-project-deletion-recovery.cjs",
    "eval:live-build-continuity": "node scripts/eval-live-build-continuity.cjs",
